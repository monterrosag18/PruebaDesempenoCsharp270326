@model SportsComplex.Models.SportsSpace
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-container">
            <h2>Create New Space</h2>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger font-weight-bold mb-3"></div>
                <div class="mb-4">
                    <label>Space Name</label>
                    <input asp-for="Name" class="form-control form-control-premium" required />
                </div>
                <div class="mb-4">
                    <label>Space Type (e.g. Soccer, Basketball)</label>
                    <input asp-for="SpaceType" class="form-control form-control-premium" required />
                </div>
                <div class="mb-4">
                    <label>Capacity (People)</label>
                    <input asp-for="Capacity" type="number" class="form-control form-control-premium" required />
                </div>
                <div class="d-flex justify-content-between mt-5">
                    <a href="/SportsSpaces" class="btn btn-outline-light">Back to List</a>
                    <button type="submit" class="btn btn-premium px-5">Save Space</button>
                </div>
            </form>
        </div>
    </div>
</div>
