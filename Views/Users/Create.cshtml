@model SportsComplex.Models.User
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-container">
            <h2>Create New User</h2>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="text-danger font-weight-bold mb-3"></div>
                <div class="mb-4">
                    <label>Document ID</label>
                    <input asp-for="Document" class="form-control form-control-premium" required />
                </div>
                <div class="mb-4">
                    <label>Full Name</label>
                    <input asp-for="Name" class="form-control form-control-premium" required />
                </div>
                <div class="mb-4">
                    <label>Phone Number</label>
                    <input asp-for="Phone" class="form-control form-control-premium" required />
                </div>
                <div class="mb-4">
                    <label>Email Address</label>
                    <input asp-for="Email" type="email" class="form-control form-control-premium" required />
                </div>
                <div class="d-flex justify-content-between mt-5">
                    <a href="/Users" class="btn btn-outline-light">Back to List</a>
                    <button type="submit" class="btn btn-premium px-5">Save User</button>
                </div>
            </form>
        </div>
    </div>
</div>
