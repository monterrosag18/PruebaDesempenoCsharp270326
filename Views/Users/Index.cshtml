@model IEnumerable<SportsComplex.Models.User>
<div class="glass-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Users Hub</h2>
        <a href="/Users/Create" class="btn btn-premium">+ New User</a>
    </div>
    
    <div class="table-responsive">
        <table class="table table-premium">
            <thead>
                <tr>
                    <th>Document</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="font-weight-bold">@item.Document</td>
                        <td>@item.Name</td>
                        <td>@item.Phone</td>
                        <td class="text-secondary">@item.Email</td>
                        <td>
                            <a href="/Users/Edit/@item.Id" class="btn btn-sm btn-outline-light">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
